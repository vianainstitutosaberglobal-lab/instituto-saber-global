---
import Base from '../layouts/Base.astro';
---
<Base title="O Instituto | Saber Global" currentPage="o-instituto">

<!-- Section 1: Hero Institucional -->
<section class="px-6 md:px-20 py-16 md:py-24 max-w-7xl mx-auto pt-24 md:pt-32">
  <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
    <div class="text-center md:text-left">
      <span data-animate="fade-up" class="text-tertiary font-bold tracking-widest text-xs uppercase mb-4 block">Institucional</span>
      <h1 data-animate="fade-up" style="transition-delay: 100ms;" class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-8 leading-[1.1]">
        Excelência Educacional Sem Fronteiras
      </h1>
      <p data-animate="fade-up" style="transition-delay: 400ms;" class="text-on-surface-variant text-base sm:text-lg leading-relaxed mb-4">
        O Instituto de Educação Saber Global é uma instituição de ensino e consultoria acadêmica sediada em Fortaleza (CE), dedicada a transformar a trajetória de profissionais brasileiros por meio da internacionalização do conhecimento.
      </p>
      <p data-animate="fade-up" style="transition-delay: 500ms;" class="text-on-surface-variant text-base sm:text-lg leading-relaxed mb-8">
        Fundado com o propósito de romper as barreiras burocráticas e geográficas, o Instituto atua como um facilitador estratégico entre estudantes brasileiros e renomadas instituições de ensino superior no exterior. Nossa estrutura é desenhada para oferecer não apenas o acesso a cursos de alta qualidade, mas uma jornada de aprendizado segura, transparente e focada no desenvolvimento humano e técnico.
      </p>
      <div data-animate="fade-up" style="transition-delay: 700ms;" class="flex justify-center md:justify-start">
        <a href="/programas" class="w-full sm:w-auto justify-center bg-gradient-to-br from-green-500 to-green-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:shadow-xl hover:-translate-y-1 hover:shadow-green-500/30 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined">school</span>
          Ver Programas Disponíveis
        </a>
      </div>
    </div>
    <div class="relative" data-animate="zoom-in" style="transition-delay: 300ms;">
      <div class="absolute -inset-4 bg-primary-fixed/30 blur-3xl rounded-full"></div>
      <img class="relative rounded-xl shadow-2xl perspective-img w-full h-auto max-h-[600px] object-cover" alt="Saber Global - Mesa com livros e diploma" src="/images/hero-instituto.png" />
    </div>
  </div>
</section>

<!-- Section 2: Missão, Visão e Valores -->
<section class="bg-surface-container-low py-16 md:py-24">
  <div class="px-6 md:px-20 max-w-7xl mx-auto">
    <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-on-surface">Nossa Missão, Visão e Valores</h2>
      <div class="h-1.5 w-24 bg-primary/20 mx-auto mt-4 rounded-full"></div>
    </div>
    
    <!-- Top Row: Missão e Visão -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <!-- MISSÃO -->
      <div data-animate="fade-up" style="transition-delay: 100ms;" class="bg-surface-container-lowest p-8 md:p-12 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent">
        <div class="w-16 h-16 bg-primary-fixed rounded-xl flex items-center justify-center text-on-primary-fixed mb-8 group-hover:bg-primary group-hover:text-on-primary transition-colors">
          <span class="material-symbols-outlined text-3xl">school</span>
        </div>
        <h3 class="text-3xl font-extrabold mb-4 text-on-surface">Missão</h3>
        <p class="text-on-surface-variant text-lg leading-relaxed">
          Promover o acesso à educação de pós-graduação internacional e formação continuada, garantindo suporte integral ao aluno e excelência pedagógica.
        </p>
      </div>

      <!-- VISÃO -->
      <div data-animate="fade-up" style="transition-delay: 250ms;" class="bg-surface-container-lowest p-8 md:p-12 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent">
        <div class="w-16 h-16 bg-secondary-fixed rounded-xl flex items-center justify-center text-on-secondary-fixed mb-8 group-hover:bg-secondary group-hover:text-on-secondary transition-colors">
          <span class="material-symbols-outlined text-3xl">trending_up</span>
        </div>
        <h3 class="text-3xl font-extrabold mb-4 text-on-surface">Visão</h3>
        <p class="text-on-surface-variant text-lg leading-relaxed">
          Ser a principal referência no Brasil em conexões acadêmicas internacionais, reconhecida pela ética, transparência e inovação no suporte ao estudante.
        </p>
      </div>
    </div>

    <!-- Bottom Row: Valores -->
    <div data-animate="fade-up" style="transition-delay: 400ms;" class="bg-surface-container-lowest p-8 md:p-12 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent">
      <div class="flex flex-col lg:flex-row gap-12 items-start relative z-10">
        <div class="lg:w-1/3">
          <div class="w-16 h-16 bg-tertiary-fixed rounded-xl flex items-center justify-center text-on-tertiary-fixed mb-8 group-hover:bg-tertiary group-hover:text-on-tertiary transition-colors">
            <span class="material-symbols-outlined text-3xl">verified_user</span>
          </div>
          <h3 class="text-3xl font-extrabold mb-4 text-on-surface">Nossos Valores</h3>
          <p class="text-on-surface-variant leading-relaxed">Os pilares que sustentam a nossa excelência educacional e o cuidado com cada trajetória profissional.</p>
        </div>
        
        <div class="lg:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-primary text-3xl">gavel</span>
              <h4 class="font-extrabold text-xl text-on-surface">Ética e Transparência</h4>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Compromisso total com a verdade e com a legalidade em todos os processos administrativos e pedagógicos.</p>
          </div>

          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-secondary text-3xl">event_available</span>
              <h4 class="font-extrabold text-xl text-on-surface">Inovação e Flexibilidade</h4>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Uso intenso de tecnologia e modalidades otimizadas para adaptar o conhecimento à rotina do aluno.</p>
          </div>

          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-tertiary text-3xl">support_agent</span>
              <h4 class="font-extrabold text-xl text-on-surface">Foco no Aluno</h4>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Suporte humano de Fortaleza que entende exatamente as necessidades individuais de cada carreira.</p>
          </div>

          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-green-600 text-3xl">handshake</span>
              <h4 class="font-extrabold text-xl text-on-surface">Parcerias Globais</h4>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Fomentamos excelentes parcerias estratégicas que valorizam o enriquecedor intercâmbio de saberes internacionais.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Parceria UNADES -->
<section class="py-16 md:py-24 px-6 md:px-20 max-w-7xl mx-auto overflow-hidden">
  <div class="bg-primary text-on-primary rounded-3xl p-8 md:p-16 flex flex-col md:flex-row gap-10 md:gap-12 items-center relative text-center md:text-left">
    <div class="md:w-1/2 z-10">
      <h2 data-animate="fade-right" style="transition-delay: 100ms;" class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6">Alianças que Fortalecem o seu Futuro</h2>
      <div data-animate="fade-right" style="transition-delay: 300ms;" class="text-primary-fixed/80 text-base md:text-lg mb-8 leading-relaxed space-y-4">
        <p>
          O Instituto Saber Global orgulha-se de manter parcerias estratégicas com instituições internacionais de prestígio, com destaque para a Universidad Del Sol (UNADES), no Paraguai. Através deste convênio, viabilizamos programas de Mestrado e Doutorado (Stricto Sensu) em modalidades que atendem à realidade do profissional moderno, como a Gestão em Saúde Pública.
        </p>
        <p>
          Nossa atuação é pautada pelo rigor acadêmico e pelo cumprimento das normas vigentes, assegurando que nossos alunos recebam a orientação necessária para o pleno aproveitamento de seus títulos no Brasil.
        </p>
      </div>
      <div data-animate="fade-right" style="transition-delay: 500ms;" class="flex justify-center md:justify-start">
        <a href="/parcerias" class="w-full sm:w-auto justify-center bg-blue-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined">handshake</span>
          Conhecer Convênios
        </a>
      </div>
    </div>
    <div class="md:w-1/2" data-animate="zoom-in" style="transition-delay: 400ms;">
      <img class="rounded-3xl shadow-2xl w-full object-cover perspective-img" alt="Universidad Del Sol - Instituto Saber Global" src="/images/del-sol-instituto.png" />
    </div>
  </div>
</section>

<!-- Section 4: Transparência Administrativa -->
<section class="bg-surface py-24 px-6 md:px-20">
  <div class="max-w-5xl mx-auto" data-animate="fade-up">
    <div class="bg-surface-container-lowest p-12 md:p-16 rounded-xl shadow-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-on-surface/5 border border-transparent group">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight mb-4 text-center">Transparência Administrativa</h2>
        <p class="text-center text-on-surface-variant text-lg mb-12 max-w-3xl mx-auto">
          O Instituto de Educação Saber Global é uma entidade ativa e regularmente constituída, operando sob as seguintes diretrizes:
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-y-12 gap-x-16 mt-8">
        <div class="flex items-start gap-5 group" data-animate="fade-up" style="transition-delay: 100ms;">
          <div class="w-14 h-14 bg-primary-fixed rounded-xl flex items-center justify-center shrink-0 group-hover:bg-primary transition-colors">
            <span class="material-symbols-outlined text-on-primary-fixed group-hover:text-white transition-colors text-3xl">corporate_fare</span>
          </div>
          <div>
            <span class="text-xs uppercase font-bold text-on-surface-variant tracking-wider">Razão Social</span>
            <p class="text-lg font-semibold text-on-surface mt-1">Instituto de Educação Saber Global</p>
          </div>
        </div>
        <div class="flex items-start gap-5 group" data-animate="fade-up" style="transition-delay: 250ms;">
          <div class="w-14 h-14 bg-secondary-fixed rounded-xl flex items-center justify-center shrink-0 group-hover:bg-secondary transition-colors">
            <span class="material-symbols-outlined text-on-secondary-fixed group-hover:text-white transition-colors text-3xl">fingerprint</span>
          </div>
          <div>
            <span class="text-xs uppercase font-bold text-on-surface-variant tracking-wider">CNPJ</span>
            <p class="text-lg font-semibold text-on-surface mt-1">63.421.082/0001-68</p>
          </div>
        </div>
        <div class="flex items-start gap-5 group" data-animate="fade-up" style="transition-delay: 400ms;">
          <div class="w-14 h-14 bg-tertiary-fixed rounded-xl flex items-center justify-center shrink-0 group-hover:bg-tertiary transition-colors">
            <span class="material-symbols-outlined text-on-tertiary-fixed group-hover:text-white transition-colors text-3xl">location_on</span>
          </div>
          <div>
            <span class="text-xs uppercase font-bold text-on-surface-variant tracking-wider">Sede Administrativa</span>
            <p class="text-lg font-semibold text-on-surface mt-1">Fortaleza - Ceará</p>
          </div>
        </div>
        <div class="flex items-start gap-5 group" data-animate="fade-up" style="transition-delay: 550ms;">
          <div class="w-14 h-14 bg-green-500/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-green-500 transition-colors">
            <span class="material-symbols-outlined text-green-600 group-hover:text-white transition-colors text-3xl">category</span>
          </div>
          <div>
            <span class="text-xs uppercase font-bold text-on-surface-variant tracking-wider">Segmento</span>
            <p class="text-base font-semibold text-on-surface leading-tight mt-1">Organização associativa ligada à cultura, arte e desenvolvimento educacional.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section 5: CTA Final -->
<section class="py-16 md:py-24 bg-surface-container-low text-center px-6">
  <div class="max-w-4xl mx-auto" data-animate="zoom-in">
    <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter mb-10 text-on-surface">Venha crescer com o Saber Global.</h2>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/programas" class="w-full sm:w-auto bg-gradient-to-br from-green-500 to-green-600 text-white px-8 md:px-10 py-4 md:py-5 rounded-xl font-bold text-lg hover:-translate-y-1 hover:shadow-xl hover:shadow-green-500/30 transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">school</span>
        Ver Programas Disponíveis
      </a>
      <a href="/contato" class="w-full sm:w-auto bg-blue-600 text-white px-8 md:px-10 py-4 md:py-5 rounded-xl font-bold text-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">support_agent</span>
        Fale com a Nossa Diretoria
      </a>
    </div>
  </div>
</section>

<!-- [SCROLL ANIMATIONS SCRIPT & STYLES] -->
<style is:global>
  /* Base animation setup */
  [data-animate] {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  /* Reset hover duration speed */
  [data-animate]:hover {
    transition-duration: 150ms !important;
  }
  
  /* Initial states */
  [data-animate="fade-up"] { transform: translateY(40px); }
  [data-animate="fade-right"] { transform: translateX(-40px); }
  [data-animate="fade-left"] { transform: translateX(40px); }
  [data-animate="zoom-in"] { transform: scale(0.93); }
  
  /* Visible state */
  [data-animate].is-visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // Setup intersection observer on page load
  function initAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Unobserve to run the animation only once
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.15, // Trigger when 15% visible
      rootMargin: "0px 0px -50px 0px" // Trigger slightly before it hits bottom of viewport
    });

    document.querySelectorAll('[data-animate]').forEach((el) => {
      observer.observe(el);
    });
  }

  // Run immediately
  initAnimations();
</script>

</Base>
