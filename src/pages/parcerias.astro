---
import Base from '../layouts/Base.astro';
---
<Base title="Parcerias | Saber Global" currentPage="parcerias">

<!-- Section 1: Hero -->
<section class="relative overflow-hidden pt-32 pb-20 md:pt-48 md:pb-32 px-6 bg-surface">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="z-10">
      <span data-animate="fade-right" class="inline-block text-tertiary font-bold tracking-widest text-xs uppercase mb-4">O PODER DA COLABORAÇÃO</span>
      <h1 data-animate="fade-up" style="transition-delay: 100ms;" class="text-5xl md:text-7xl font-black text-on-surface tracking-tighter leading-[1.1] mb-8">
        Alianças Estratégicas para uma Educação Global
      </h1>
      <p data-animate="fade-up" style="transition-delay: 200ms;" class="text-on-surface-variant leading-relaxed mb-8 max-w-xl text-justify text-lg">
        No Instituto Saber Global, acreditamos que a excelência acadêmica nasce da união de forças. Por isso, estabelecemos parcerias com instituições de renome internacional e entidades de classe para oferecer aos nossos alunos um ecossistema de aprendizado robusto, legalmente amparado e focado na inovação. Nossas parcerias são a garantia de que o seu certificado ou diploma possui o lastro de instituições comprometidas com a qualidade.
      </p>
      <div data-animate="fade-up" style="transition-delay: 400ms;" class="flex flex-wrap gap-4 pt-4">
        <div class="flex items-center gap-3 px-6 py-3 bg-surface-container-lowest shadow-sm border border-outline-variant/10 rounded-2xl hover:-translate-y-1 transition-transform cursor-default">
          <div class="w-10 h-10 rounded-lg bg-primary-fixed flex items-center justify-center text-on-primary-fixed">
            <span class="material-symbols-outlined">handshake</span>
          </div>
          <span class="text-sm font-bold text-on-surface">Rede Global</span>
        </div>
        <div class="flex items-center gap-3 px-6 py-3 bg-surface-container-lowest shadow-sm border border-outline-variant/10 rounded-2xl hover:-translate-y-1 transition-transform cursor-default">
          <div class="w-10 h-10 rounded-lg bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed">
            <span class="material-symbols-outlined">gavel</span>
          </div>
          <span class="text-sm font-bold text-on-surface">Respaldo Jurídico</span>
        </div>
      </div>
    </div>
    <div class="relative" data-animate="zoom-in" style="transition-delay: 300ms;">
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="relative rounded-[2rem] overflow-hidden perspective-img shadow-2xl shadow-primary/20">
        <img alt="Colaboração acadêmica internacional" class="w-full h-auto max-h-[600px] object-contain bg-surface-container-lowest" src="/images/hero-parcerias.png" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>

<!-- Section 2: UNADES -->
<section class="py-24 px-6 bg-surface-container-low">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row gap-12 items-center">
      <div class="lg:w-1/3" data-animate="fade-right">
        <div class="relative rounded-[2rem] p-6 flex flex-col justify-end overflow-hidden group min-h-[500px] shadow-xl cursor-pointer hover:shadow-2xl hover:-translate-y-1 transition-all border border-transparent">
          <img alt="Campus UNADES" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src="/images/parcerias-unades.png" />
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors duration-500"></div>
          
          <div class="relative z-10 mt-auto bg-white/50 backdrop-blur-md p-8 rounded-[1.5rem] shadow-sm border border-white/50 group-hover:bg-white/80 transition-colors">
            <h2 class="text-2xl font-black tracking-tight text-on-surface mb-1 drop-shadow-sm">Universidad Del Sol</h2>
            <p class="text-sm font-bold text-primary mb-4 flex items-center gap-1">
              (UNADES)
            </p>
            <p class="text-xs font-bold text-tertiary uppercase tracking-widest mb-4 flex items-center gap-1 drop-shadow-sm">
              <span class="material-symbols-outlined text-[1rem]">location_on</span> Paraguai
            </p>
            <p class="text-on-surface-variant text-sm leading-relaxed text-justify border-t border-outline-variant/20 pt-4 font-medium drop-shadow-sm">
              A UNADES é uma instituição de ensino superior de destaque no Paraguai, reconhecida por sua infraestrutura e rigor acadêmico.
            </p>
          </div>
        </div>
      </div>
      <div class="lg:w-2/3">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="col-span-full mb-4" data-animate="fade-up">
            <h3 class="text-3xl font-black tracking-tighter text-on-surface">Nosso Principal Parceiro Internacional</h3>
            <p class="text-on-surface-variant mt-2 italic">Através deste convênio oficial, o Instituto Saber Global atua como o braço de apoio ao aluno brasileiro, facilitando:</p>
          </div>
          <div data-animate="fade-up" style="transition-delay: 100ms;" class="bg-surface-container-lowest p-8 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent">
            <div class="w-16 h-16 bg-primary-fixed rounded-xl flex items-center justify-center text-on-primary-fixed mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
              <span class="material-symbols-outlined text-3xl">school</span>
            </div>
            <h4 class="text-xl font-bold mb-3 tracking-tight text-on-surface">Acesso a Programas de Stricto Sensu</h4>
            <p class="text-on-surface-variant text-sm border-t border-outline-variant/10 pt-4">Mestrados e Doutorados com grades curriculares modernas e adaptadas.</p>
          </div>
          <div data-animate="fade-up" style="transition-delay: 250ms;" class="bg-surface-container-lowest p-8 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent">
            <div class="w-16 h-16 bg-secondary-fixed rounded-xl flex items-center justify-center text-on-secondary-fixed mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
              <span class="material-symbols-outlined text-3xl">flight_takeoff</span>
            </div>
            <h4 class="text-xl font-bold mb-3 tracking-tight text-on-surface">Mobilidade Acadêmica</h4>
            <p class="text-on-surface-variant text-sm border-t border-outline-variant/10 pt-4">Integração entre estudantes do Mercosul para desenvolvimento profissional.</p>
          </div>
          <div data-animate="fade-up" style="transition-delay: 400ms;" class="bg-surface-container-lowest p-8 rounded-xl transition-all hover:-translate-y-1 active:scale-[0.98] cursor-pointer hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent md:col-span-2 flex flex-col md:flex-row items-start md:items-center gap-6">
            <div class="w-16 h-16 bg-tertiary-fixed rounded-xl flex items-center justify-center text-on-tertiary-fixed flex-shrink-0 group-hover:bg-tertiary group-hover:text-white transition-colors">
              <span class="material-symbols-outlined text-3xl">hub</span>
            </div>
            <div>
              <h4 class="text-xl font-bold mb-2 tracking-tight text-on-surface">Intercâmbio de Saberes</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">Corpo docente internacional e troca de experiências transfronteiriças de ponta para profissionais focados em inovação.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Rede de Convênios -->
<section class="py-24 px-6 bg-surface">
  <div class="max-w-7xl mx-auto text-center mb-16" data-animate="fade-up">
    <h2 class="text-4xl font-black tracking-tighter text-on-surface mb-4">Como Nossas Parcerias Beneficiam Você</h2>
    <p class="text-on-surface-variant text-lg max-w-2xl mx-auto mb-8">Além das instituições de ensino, buscamos constantemente acordos com organizações que agregam valor à sua jornada:</p>
    <div class="h-1.5 w-24 bg-amber-500 mx-auto rounded-full"></div>
  </div>
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <div data-animate="fade-up" style="transition-delay: 100ms;" class="bg-surface-container-lowest p-10 rounded-xl flex flex-col items-center text-center transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent active:scale-[0.98] cursor-pointer">
      <div class="w-20 h-20 bg-primary-fixed rounded-2xl flex items-center justify-center text-on-primary-fixed mb-8 group-hover:bg-primary group-hover:text-white transition-colors">
        <span class="material-symbols-outlined text-4xl">account_balance</span>
      </div>
      <h3 class="text-xl font-bold mb-4">Conselhos e Associações Profissionais</h3>
      <p class="text-on-surface-variant text-sm leading-relaxed flex-grow">Parcerias voltadas para descontos e condições especiais para membros de categorias específicas (Saúde, Educação e Gestão).</p>
    </div>
    <div data-animate="fade-up" style="transition-delay: 250ms;" class="bg-surface-container-lowest p-10 rounded-xl flex flex-col items-center text-center transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent active:scale-[0.98] cursor-pointer">
      <div class="w-20 h-20 bg-secondary-fixed rounded-2xl flex items-center justify-center text-on-secondary-fixed mb-8 group-hover:bg-secondary group-hover:text-white transition-colors">
        <span class="material-symbols-outlined text-4xl">devices</span>
      </div>
      <h3 class="text-xl font-bold mb-4">Plataformas de Tecnologia Educacional</h3>
      <p class="text-on-surface-variant text-sm leading-relaxed flex-grow">Uso de ferramentas de ponta para garantir que o ensino a distância (EAD) tenha a mesma interatividade do presencial.</p>
    </div>
    <div data-animate="fade-up" style="transition-delay: 400ms;" class="bg-surface-container-lowest p-10 rounded-xl flex flex-col items-center text-center transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-on-surface/5 group border border-transparent active:scale-[0.98] cursor-pointer">
      <div class="w-20 h-20 bg-tertiary-fixed rounded-2xl flex items-center justify-center text-on-tertiary-fixed mb-8 group-hover:bg-tertiary group-hover:text-white transition-colors">
        <span class="material-symbols-outlined text-4xl">verified_user</span>
      </div>
      <h3 class="text-xl font-bold mb-4">Consultorias de Reconhecimento</h3>
      <p class="text-on-surface-variant text-sm leading-relaxed flex-grow">Colaboração com especialistas em legislação educacional para orientar o processo de reconhecimento de títulos no Brasil.</p>
    </div>
  </div>
</section>

<!-- Section 4: Seja um Parceiro -->
<section class="py-32 px-6 bg-surface">
  <div data-animate="zoom-in" class="max-w-5xl mx-auto bg-gradient-to-br from-primary to-primary-container rounded-[2rem] p-12 md:p-20 text-center text-on-primary relative overflow-hidden shadow-2xl shadow-primary/20">
    <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 blur-xl"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-500/10 rounded-full -ml-24 -mb-24 blur-xl"></div>
    <div class="relative z-10 space-y-6">
      <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter leading-tight mb-6">Sua Instituição Conectada ao Mundo</h2>
      <p class="text-primary-fixed/80 text-lg max-w-2xl mx-auto mb-10 text-justify md:text-center">
        Você representa uma prefeitura, empresa, conselho profissional ou instituição de ensino? O Instituto Saber Global está aberto a novos convênios que visem o desenvolvimento de pessoas e a democratização do conhecimento de alto nível.
      </p>
      <a href="/contato" class="bg-gradient-to-br from-green-500 to-green-600 text-white w-full sm:w-auto px-10 py-5 rounded-xl font-bold text-lg hover:shadow-xl hover:-translate-y-1 hover:shadow-green-500/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer mx-auto max-w-[400px]">
        <span class="material-symbols-outlined">handshake</span>
        Seja um Parceiro Institucional
      </a>
    </div>
  </div>
</section>

<!-- Section 5: CTA Final -->
<section class="py-24 bg-surface-container-low text-center px-6">
  <div class="max-w-4xl mx-auto" data-animate="zoom-in">
    <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-6 text-on-surface">Estude em uma instituição com respaldo.</h2>
    <p class="text-on-surface-variant text-lg mb-10">Transparência e seriedade em cada convênio firmado.</p>
    <div class="flex flex-col md:flex-row gap-4 justify-center">
      <a href="/contato" class="bg-blue-600 text-white px-10 py-5 rounded-xl font-bold text-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">description</span>
        Ver Documentos
      </a>
    </div>
  </div>
</section>

<style is:global>
  /* Base animation setup */
  [data-animate] {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  /* Reset hover duration speed */
  [data-animate]:hover {
    transition-duration: 150ms !important;
  }
  
  /* Initial states */
  [data-animate="fade-up"] { transform: translateY(40px); }
  [data-animate="fade-right"] { transform: translateX(-40px); }
  [data-animate="fade-left"] { transform: translateX(40px); }
  [data-animate="zoom-in"] { transform: scale(0.93); }
  
  /* Visible state */
  [data-animate].is-visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // Setup intersection observer on page load
  function initAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Unobserve to run the animation only once
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.15, // Trigger when 15% visible
      rootMargin: "0px 0px -50px 0px" // Trigger slightly before it hits bottom of viewport
    });

    document.querySelectorAll('[data-animate]').forEach((el) => {
      observer.observe(el);
    });
  }

  // Run immediately
  initAnimations();
</script>

</Base>
