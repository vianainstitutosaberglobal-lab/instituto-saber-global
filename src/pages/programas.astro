---
import Base from '../layouts/Base.astro';
---
<Base title="Programas Internacionais | Instituto Saber Global" currentPage="programas">

<!-- Section 1: Hero -->
<section class="relative pt-24 pb-16 md:pt-48 md:pb-32 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
    <div class="z-10 space-y-8 text-center lg:text-left">
      <span data-animate="fade-right" class="inline-block px-4 py-1.5 rounded-full bg-tertiary-fixed text-on-tertiary-fixed-variant text-xs font-bold tracking-widest uppercase">
        Excelência Acadêmica
      </span>
      <h1 data-animate="fade-up" style="transition-delay: 100ms;" class="text-4xl sm:text-5xl md:text-7xl font-black tracking-tighter text-on-surface leading-[1.1]">
        Transforme sua Carreira com Títulos de <span class="text-primary italic">Peso Internacional</span>
      </h1>
      <div data-animate="fade-up" style="transition-delay: 400ms;" class="text-lg md:text-xl text-on-surface-variant max-w-xl mx-auto lg:mx-0 leading-relaxed space-y-4">
        <p>
          O Instituto Saber Global, em parceria estratégica com a Universidad Del Sol (UNADES - Paraguai), oferece programas de Pós-Graduação Stricto Sensu desenhados para o profissional brasileiro que busca excelência acadêmica, flexibilidade e suporte especializado.
        </p>
        <p>
          Nossos programas são estruturados para atender aos rigorosos padrões de qualidade do Mercosul, proporcionando uma experiência multicultural e de alto impacto científico.
        </p>
      </div>
      <div data-animate="fade-up" style="transition-delay: 700ms;" class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4">
        <a href="#mestrado-saude-publica" class="w-full sm:w-auto bg-gradient-to-br from-green-500 to-green-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:shadow-xl hover:-translate-y-1 hover:shadow-green-500/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer">
          <span class="material-symbols-outlined">school</span>
          Ver Programas
        </a>
        <a href="/contato" class="w-full sm:w-auto bg-blue-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer">
          <span class="material-symbols-outlined">support_agent</span>
          Consultar Vagas
        </a>
      </div>
    </div>
    <div class="relative" data-animate="zoom-in" style="transition-delay: 300ms;">
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="relative rounded-[2rem] overflow-hidden perspective-img shadow-2xl shadow-primary/20">
        <img alt="Campus universitário moderno" class="w-full h-auto max-h-[600px] object-cover bg-surface-container-lowest" src="/images/unades-programas.png" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>

<!-- Section 2: Program Cards -->
<section class="bg-surface-container-low py-16 md:py-24" id="mestrado-saude-publica">
  <div class="max-w-7xl mx-auto px-6 md:px-20">
    <div class="mb-12 md:mb-16 text-center md:text-left" data-animate="fade-up">
      <h2 class="text-3xl font-bold tracking-tight text-on-surface mb-4">Programas de Stricto Sensu</h2>
      <p class="text-on-surface-variant">Titulações internacionais com validade técnica no Mercosul.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      <div data-animate="fade-up" style="transition-delay: 100ms;" class="bg-surface-container-lowest rounded-3xl p-8 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-on-surface/5 flex flex-col h-full group border border-transparent active:scale-[0.98] cursor-pointer">
        <div class="w-16 h-16 bg-primary-fixed rounded-2xl flex items-center justify-center mb-8 group-hover:bg-primary transition-colors">
          <span class="material-symbols-outlined text-on-primary-fixed group-hover:text-white transition-colors text-3xl">school</span>
        </div>
        <h3 class="text-2xl font-bold text-on-surface mb-4">Mestrado em Gestão em Saúde Pública</h3>
        <p class="text-on-surface-variant mb-4 font-medium">Destaque: Foco em políticas públicas, epidemiologia e gestão estratégica.</p>
        <p class="text-on-surface-variant mb-8 flex-grow text-sm">Público-alvo: Gestores, médicos, enfermeiros e profissionais da área da saúde que buscam liderar processos no setor público e privado.</p>
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3 text-sm">
            <div class="w-8 h-8 rounded-full bg-secondary/15 flex items-center justify-center shrink-0 text-secondary">
              <span class="material-symbols-outlined text-base">schedule</span>
            </div>
            <span class="font-medium text-on-surface">Duração Média: 24 meses</span>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <div class="w-8 h-8 rounded-full bg-secondary/15 flex items-center justify-center shrink-0 text-secondary pb-0.5">
              <span class="material-symbols-outlined text-base">language</span>
            </div>
            <span class="font-medium text-on-surface">Modalidade: EAD / Híbrido<br/><span class="text-xs text-on-surface-variant font-normal">(conforme cronograma)</span></span>
          </li>
        </ul>
        <a href="/contato" class="bg-blue-600 text-white inline-flex justify-center w-full sm:w-auto px-8 sm:px-16 md:min-w-[280px] py-4 md:py-3.5 rounded-xl font-bold hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all text-center active:scale-95 cursor-pointer mx-auto">
          Ver Detalhes do Edital
        </a>
      </div>
      <div data-animate="fade-up" style="transition-delay: 300ms;" id="doutorados" class="bg-surface-container-lowest rounded-3xl p-8 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-on-surface/5 flex flex-col h-full group border border-transparent active:scale-[0.98] cursor-pointer">
        <div class="w-16 h-16 bg-tertiary-fixed rounded-2xl flex items-center justify-center mb-8 group-hover:bg-tertiary transition-colors">
          <span class="material-symbols-outlined text-on-tertiary-fixed group-hover:text-white transition-colors text-3xl">history_edu</span>
        </div>
        <h3 class="text-2xl font-bold text-on-surface mb-4">Doutorado Internacional <br/><span class="text-lg text-on-surface-variant font-normal">(Consultar Áreas)</span></h3>
        <p class="text-on-surface-variant mb-4 font-medium">Diferencial: Orientação acadêmica próxima e suporte para a qualificação da tese.</p>
        <p class="text-on-surface-variant mb-8 flex-grow text-sm">Objetivo: Formação de pesquisadores e docentes de alto nível para a produção de conhecimento original e inovador.</p>
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3 text-sm">
            <div class="w-8 h-8 rounded-full bg-secondary/15 flex items-center justify-center shrink-0 text-secondary">
              <span class="material-symbols-outlined text-base">schedule</span>
            </div>
            <span class="font-medium text-on-surface">Duração Média: 36 a 48 meses</span>
          </li>
        </ul>
        <a href="/contato" class="bg-blue-600 text-white inline-flex justify-center w-full sm:w-auto px-8 sm:px-16 md:min-w-[280px] py-4 md:py-3.5 rounded-xl font-bold hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all text-center active:scale-95 cursor-pointer mx-auto">
          Ver Detalhes do Edital
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Diferenciais Bento Grid -->
<section class="py-16 md:py-24 px-6 bg-primary text-on-primary relative overflow-hidden">
  <!-- Background Animations -->
  <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-[#1ca1ff] opacity-10 rounded-full blur-[100px] animate-pulse pointer-events-none" style="animation-duration: 6s;"></div>
  <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#42a8f5] opacity-20 rounded-full blur-[150px] animate-pulse pointer-events-none" style="animation-duration: 9s;"></div>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-12 md:mb-16 text-center md:text-left flex flex-col md:block items-center" data-animate="fade-up">
      <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-4 text-white">Diferenciais da Parceria UNADES</h2>
      <div class="h-1.5 w-24 rounded-full mb-4" style="background-color: #f5a623;"></div>
      <p class="text-blue-100 text-lg">Por que escolher o Instituto Saber Global para sua formação internacional?</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div data-animate="fade-up" style="transition-delay: 100ms;" class="bg-[#185880] p-8 rounded-xl shadow-lg border border-transparent flex flex-col transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 group">
        <div class="w-16 h-16 bg-primary-fixed rounded-xl flex items-center justify-center text-on-primary-fixed mb-6 group-hover:bg-primary group-hover:text-on-primary transition-colors">
          <span class="material-symbols-outlined text-3xl">support_agent</span>
        </div>
        <h4 class="text-xl font-bold mb-2 text-white">Suporte em Português</h4>
        <p class="text-sm text-blue-100 leading-relaxed">Todo o processo de matrícula e acompanhamento administrativo é realizado pelo Instituto Saber Global.</p>
      </div>
      <div data-animate="fade-up" style="transition-delay: 250ms;" class="bg-[#185880] p-8 rounded-xl shadow-lg border border-transparent flex flex-col transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 group">
        <div class="w-16 h-16 bg-secondary-fixed rounded-xl flex items-center justify-center text-on-secondary-fixed mb-6 group-hover:bg-secondary group-hover:text-on-secondary transition-colors">
          <span class="material-symbols-outlined text-3xl">calendar_month</span>
        </div>
        <h4 class="text-xl font-bold mb-2 text-white">Cronogramas Adaptados</h4>
        <p class="text-sm text-blue-100 leading-relaxed">Datas pensadas para conciliar a vida profissional no Brasil com a formação acadêmica internacional.</p>
      </div>
      <div data-animate="fade-up" style="transition-delay: 400ms;" class="bg-[#185880] p-8 rounded-xl shadow-lg border border-transparent flex flex-col transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 group">
        <div class="w-16 h-16 bg-tertiary-fixed rounded-xl flex items-center justify-center text-on-tertiary-fixed mb-6 group-hover:bg-tertiary group-hover:text-on-tertiary transition-colors">
          <span class="material-symbols-outlined text-3xl">payments</span>
        </div>
        <h4 class="text-xl font-bold mb-2 text-white">Custo-Benefício</h4>
        <p class="text-sm text-blue-100 leading-relaxed">Acesso a títulos de doutor e mestre com investimentos competitivos em relação ao mercado nacional.</p>
      </div>
      <div data-animate="fade-up" style="transition-delay: 550ms;" class="bg-[#185880] p-8 rounded-xl shadow-lg border border-transparent flex flex-col transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 group">
        <div class="w-16 h-16 bg-surface-container-lowest rounded-xl flex items-center justify-center text-primary mb-6 group-hover:bg-green-500 group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-3xl">public</span>
        </div>
        <h4 class="text-xl font-bold mb-2 text-white">Conexão Mercosul</h4>
        <p class="text-sm text-blue-100 leading-relaxed">Facilidade de trânsito acadêmico e acordos de cooperação regional.</p>
      </div>
    </div>
  </div>
</section>

<!-- Section 4: Jornada -->
<section class="py-24 bg-surface-container-highest">
  <div class="max-w-7xl mx-auto px-6 md:px-20">
    <h2 data-animate="fade-up" class="text-3xl font-bold text-center text-on-surface mb-20">O Caminho para o seu Título</h2>
    <div class="relative">
      <div class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-outline-variant/30"></div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 relative">
        <div data-animate="fade-up" style="transition-delay: 100ms;" class="flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-primary-fixed rounded-full flex items-center justify-center mb-6 shadow-lg z-10 hover:scale-110 transition-transform cursor-pointer border-[6px] border-surface-container-highest">
            <span class="material-symbols-outlined text-on-primary-fixed text-4xl">assignment_turned_in</span>
          </div>
          <h5 class="font-bold text-on-surface mb-2">1. Inscrição e Matrícula</h5>
          <p class="text-xs text-on-surface-variant">Assessoria completa na documentação necessária para ingresso na UNADES.</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 200ms;" class="flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-secondary-fixed rounded-full flex items-center justify-center mb-6 shadow-lg z-10 hover:scale-110 transition-transform cursor-pointer border-[6px] border-surface-container-highest">
            <span class="material-symbols-outlined text-on-secondary-fixed text-4xl">menu_book</span>
          </div>
          <h5 class="font-bold text-on-surface mb-2">2. Ciclo de Créditos</h5>
          <p class="text-xs text-on-surface-variant">Aulas teóricas e seminários avançados.</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 300ms;" class="flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-tertiary-fixed rounded-full flex items-center justify-center mb-6 shadow-lg z-10 hover:scale-110 transition-transform cursor-pointer border-[6px] border-surface-container-highest">
            <span class="material-symbols-outlined text-on-tertiary-fixed text-4xl">biotech</span>
          </div>
          <h5 class="font-bold text-on-surface mb-2">3. Pesquisa e Tese</h5>
          <p class="text-xs text-on-surface-variant">Desenvolvimento do trabalho científico sob orientação qualificada.</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 400ms;" class="flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-primary-fixed-dim rounded-full flex items-center justify-center mb-6 shadow-lg z-10 hover:scale-110 transition-transform cursor-pointer border-[6px] border-surface-container-highest">
            <span class="material-symbols-outlined text-on-primary-fixed text-4xl">gavel</span>
          </div>
          <h5 class="font-bold text-on-surface mb-2">4. Defesa</h5>
          <p class="text-xs text-on-surface-variant">Ato acadêmico oficial para a obtenção do grau.</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 500ms;" class="flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-amber-200 rounded-full flex items-center justify-center mb-6 shadow-lg z-10 hover:scale-110 transition-transform cursor-pointer border-[6px] border-surface-container-highest">
            <span class="material-symbols-outlined text-amber-900 text-4xl">verified_user</span>
          </div>
          <h5 class="font-bold text-on-surface mb-2">5. Assessoria para Reconhecimento</h5>
          <p class="text-xs text-on-surface-variant">Orientações sobre os trâmites legais no Brasil via Plataforma Carolina Bori.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="py-16 md:py-32 px-6 bg-surface">
  <div data-animate="zoom-in" class="max-w-5xl mx-auto bg-gradient-to-br from-primary to-primary-container rounded-[2rem] p-8 md:p-20 text-center space-y-6 md:space-y-8 shadow-2xl relative overflow-hidden shadow-primary/20">
    <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 blur-xl"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-500/10 rounded-full -ml-24 -mb-24 blur-xl"></div>
    <div class="relative z-10 space-y-4 md:space-y-6">
      <h2 class="text-3xl md:text-5xl font-black text-on-primary leading-tight">
        Pronto para o Próximo Passo?
      </h2>
      <p class="text-primary-fixed/80 text-base md:text-lg mb-12 max-w-2xl mx-auto">Solicite o edital completo de 2026 e receba uma consultoria gratuita com nossos especialistas em carreira acadêmica.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 pt-4">
        <a href="/contato" class="w-full sm:w-auto bg-gradient-to-br from-green-500 to-green-600 text-white px-8 md:px-10 py-4 md:py-5 rounded-xl font-bold text-lg hover:shadow-xl hover:-translate-y-1 hover:shadow-green-500/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer">
          <span class="material-symbols-outlined">download</span>
          Baixar Edital
        </a>
        <a href="/contato" class="w-full sm:w-auto bg-blue-600 text-white px-8 md:px-10 py-4 md:py-5 rounded-xl font-bold text-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 hover:shadow-blue-600/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer">
          <span class="material-symbols-outlined">chat_bubble</span>
          Falar com Consultor
        </a>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Base animation setup */
  [data-animate] {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  /* Reset hover duration speed */
  [data-animate]:hover {
    transition-duration: 150ms !important;
  }
  
  /* Initial states */
  [data-animate="fade-up"] { transform: translateY(40px); }
  [data-animate="fade-right"] { transform: translateX(-40px); }
  [data-animate="fade-left"] { transform: translateX(40px); }
  [data-animate="zoom-in"] { transform: scale(0.93); }
  
  /* Visible state */
  [data-animate].is-visible {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // Setup intersection observer on page load
  function initAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Unobserve to run the animation only once
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.15, // Trigger when 15% visible
      rootMargin: "0px 0px -50px 0px" // Trigger slightly before it hits bottom of viewport
    });

    document.querySelectorAll('[data-animate]').forEach((el) => {
      observer.observe(el);
    });
  }

  // Run immediately
  initAnimations();
</script>

</Base>
