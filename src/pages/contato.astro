        <div class="relative z-10 text-center lg:text-left">
          <h2 class="text-2xl md:text-3xl font-black tracking-tight mb-6">Solicite uma Consultoria Gratuita</h2>
          <p class="text-blue-100 text-sm md:text-base font-medium leading-relaxed bg-white/5 p-4 rounded-2xl border border-white/10 mb-8 backdrop-blur-sm shadow-inner text-center md:text-justify">
            Preencha os dados e um de nossos coordenadores entrará em contato para analisar seu perfil acadêmico profundamente.
          </p>
          <ul class="space-y-6">
            <li class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-blue-500 shadow-md flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-white">search</span>
              </div>
              <span class="text-sm font-bold text-blue-50">Análise de currículo gratuita</span>
            </li>
            <li class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-green-500 shadow-md flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-white">handshake</span>
              </div>
              <span class="text-sm font-bold text-blue-50">Orientação sobre convênios</span>
            </li>
            <li class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-amber-500 shadow-md flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-white">gavel</span>
              </div>
              <span class="text-sm font-bold text-blue-50">Tira-dúvidas de reconhecimento</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="lg:w-3/5 p-8 md:p-12 lg:p-14 bg-white flex flex-col justify-center">
        <div class="space-y-6">
          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <div class="space-y-2">
              <label class="text-xs font-black text-on-surface-variant uppercase ml-2 tracking-widest">Nome Completo</label>
              <input class="w-full bg-surface-container-low border border-outline-variant/20 rounded-[1rem] p-4 text-on-surface focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none font-medium" placeholder="Digite seu nome completo" type="text" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-black text-on-surface-variant uppercase ml-2 tracking-widest">E-mail</label>
              <input class="w-full bg-surface-container-low border border-outline-variant/20 rounded-[1rem] p-4 text-on-surface focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none font-medium" placeholder="seu@email.com" type="email" />
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-black text-on-surface-variant uppercase ml-2 tracking-widest">WhatsApp</label>
              <input class="w-full bg-surface-container-low border border-outline-variant/20 rounded-[1rem] p-4 text-on-surface focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none font-medium" placeholder="(00) 00000-0000" type="tel" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-black text-on-surface-variant uppercase ml-2 tracking-widest">Área de Interesse</label>
              <div class="relative">
                <select class="w-full bg-surface-container-low border border-outline-variant/20 rounded-[1rem] p-4 text-on-surface focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none appearance-none font-medium pr-10">
                  <option>Mestrado em Saúde Pública</option>
                  <option>Doutorado Internacional</option>
                  <option>Formação Continuada</option>
                  <option>Dúvidas em Geral</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                  <span class="material-symbols-outlined text-outline">expand_more</span>
                </div>
              </div>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-black text-on-surface-variant uppercase ml-2 tracking-widest">Mensagem</label>
            <textarea class="w-full bg-surface-container-low border border-outline-variant/20 rounded-[1rem] p-4 text-on-surface focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none font-medium resize-none" placeholder="Conte-nos como podemos ajudar..." rows="4"></textarea>
          </div>
          <button type="submit" class="w-full bg-gradient-to-br from-green-500 to-green-600 text-white mt-4 py-5 rounded-[1.25rem] font-bold text-lg shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:shadow-green-500/30 transition-all flex items-center justify-center gap-2 active:scale-95 cursor-pointer">
            <span class="material-symbols-outlined">send</span>
            Enviar Solicitação
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Onde Estamos -->
<section class="py-16 md:py-24 max-w-7xl mx-auto px-6">
  <div class="grid lg:grid-cols-3 gap-10 md:gap-12 items-center">
    <div class="lg:col-span-1 text-center lg:text-left" data-animate="fade-right">
      <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6 text-on-surface">Onde Estamos</h2>
      <p class="text-on-surface-variant text-base md:text-lg leading-relaxed mb-8">
