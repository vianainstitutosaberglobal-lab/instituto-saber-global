---
import Base from '../layouts/Base.astro';
---
<Base title="Contato | Instituto Saber Global" currentPage="contato">

<!-- Section 1: Hero & Contatos -->
<section class="max-w-7xl mx-auto px-6 mb-24 pt-32">
  <div class="grid lg:grid-cols-2 gap-16 items-center">
    <div>
      <span class="text-tertiary font-bold tracking-widest text-xs uppercase mb-4 block">Atendimento Exclusivo</span>
      <h1 class="text-5xl md:text-6xl font-extrabold text-on-surface tracking-tighter leading-tight mb-8">
        Estamos prontos para orientar sua jornada acadêmica.
      </h1>
      <p class="text-on-surface-variant text-lg leading-relaxed mb-12 max-w-lg">
        Escolha o canal de sua preferência e fale com nossa equipe de consultores especializados em educação internacional e formação continuada.
      </p>
      <div class="grid sm:grid-cols-2 gap-6">
        <a href="https://wa.me/5585999990000" target="_blank" rel="noopener noreferrer" class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow block">
          <div class="w-12 h-12 bg-secondary/10 rounded-full flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-secondary">chat_bubble</span>
          </div>
          <h3 class="font-bold text-on-surface mb-1">WhatsApp Comercial</h3>
          <p class="text-sm text-on-surface-variant">Atendimento ágil para dúvidas sobre matrículas e editais.</p>
        </a>
        <a href="mailto:contato@institutosaberglobal.com.br" class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow block">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-primary">mail</span>
          </div>
          <h3 class="font-bold text-on-surface mb-1">E-mail Institucional</h3>
          <p class="text-sm text-on-surface-variant">Para envio de documentação e parcerias corporativas.</p>
        </a>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-tertiary/10 rounded-full flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-tertiary">call</span>
          </div>
          <h3 class="font-bold text-on-surface mb-1">Telefone Fixo</h3>
          <p class="text-sm text-on-surface-variant">(85) 3000-0000</p>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-secondary/10 rounded-full flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-secondary">location_on</span>
          </div>
          <h3 class="font-bold text-on-surface mb-1">Endereço</h3>
          <p class="text-sm text-on-surface-variant">Fortaleza, Ceará (Sede Administrativa).</p>
        </div>
      </div>
    </div>
    <div class="relative hidden lg:block">
      <div class="absolute -top-12 -left-12 w-64 h-64 bg-amber-500/10 rounded-full blur-3xl -z-10"></div>
      <div class="absolute -bottom-12 -right-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl -z-10"></div>
      <img alt="Consultores acadêmicos em ambiente moderno" class="rounded-xl shadow-2xl object-cover w-full h-[600px]" src="/images/contato-consultants.png" />
    </div>
  </div>
</section>

<!-- Section 2: Formulário de Consultoria -->
<section class="bg-surface-container-low py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-2xl grid lg:grid-cols-5">
      <div class="lg:col-span-2 bg-gradient-to-br from-primary to-primary-container p-12 text-on-primary flex flex-col justify-between">
                  <h2 class="text-3xl font-bold tracking-tight mb-6">Solicite uma Consultoria Gratuita</h2>
          <p class="text-primary-fixed opacity-90 leading-relaxed">
            Preencha os dados abaixo e um de nossos coordenadores entrará em contato para analisar seu perfil acadêmico.
          </p>
        </div>
        <ul class="space-y-4 mt-12">
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-amber-400">check_circle</span>
            <span class="text-sm">Análise de currículo gratuita</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-amber-400">check_circle</span>
            <span class="text-sm">Orientação sobre convênios</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-amber-400">check_circle</span>
            <span class="text-sm">Tira-dúvidas sobre reconhecimento</span>
          </li>
        </ul>
      </div>
      <div class="lg:col-span-3 p-12">
        <div class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase ml-2">Nome Completo</label>
              <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="Digite seu nome completo" type="text" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase ml-2">E-mail</label>
              <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="seu@email.com" type="email" />
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase ml-2">Telefone/WhatsApp</label>
              <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="(00) 00000-0000" type="tel" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-on-surface-variant uppercase ml-2">Área de Interesse</label>
              <select class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all outline-none appearance-none">
                <option>Mestrado em Gestão em Saúde Pública</option>
                <option>Doutorado Internacional</option>
                <option>Cursos de Formação Continuada</option>
                <option>Dúvidas sobre Reconhecimento de Título</option>
              </select>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-on-surface-variant uppercase ml-2">Mensagem</label>
            <textarea class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="" rows="4"></textarea>
          </div>
          <button class="w-full bg-gradient-to-br from-primary to-primary-container text-on-primary py-4 rounded-xl font-bold hover:opacity-90 transition-opacity shadow-lg shadow-primary/20">
            Enviar Solicitação
          </button>ação
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Onde Estamos -->
<section class="py-24 max-w-7xl mx-auto px-6">
  <div class="grid lg:grid-cols-3 gap-12 items-center">
    <div class="lg:col-span-1">
      <h2 class="text-4xl font-extrabold tracking-tighter mb-6">Onde Estamos</h2>
      <p class="text-on-surface-variant leading-relaxed mb-8">
        Localizados estrategicamente em Fortaleza, atendemos alunos de todo o Brasil através de nossa plataforma digital e suporte presencial agendado.
      </p>
      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="material-symbols-outlined text-primary">schedule</span>
          <div>
            <h4 class="font-bold">Horário de Funcionamento</h4>
            <p class="text-sm text-on-surface-variant">Segunda a Sexta, das 08h às 18h.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="lg:col-span-2 rounded-xl overflow-hidden shadow-xl border border-outline-variant/10 h-[450px] relative">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3981.3!2d-38.5!3d-3.73!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zM8KwNDMnNDgiUyAzOMKwMzAnMDAiVw!5e0!3m2!1spt-BR!2sbr!4v1"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Localização Instituto Saber Global"
      ></iframe>
      <div class="absolute bottom-4 left-4 bg-white px-4 py-2 rounded-lg shadow-lg">
        <span class="text-xs font-bold text-primary">Saber Global — Fortaleza, CE</span>
      </div>
    </div>
  </div>
</section>

<!-- Section 4: Redes Sociais -->
<section class="bg-surface py-12 border-t border-outline-variant/10">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight mb-4">Siga o Saber Global</h2>
    <p class="text-on-surface-variant leading-relaxed max-w-2xl mx-auto mb-10">
      Fique por dentro de novos convênios, prazos de inscrição e conteúdos educativos diários.
    </p>
    <div class="flex justify-center gap-8 mb-16">
      <a class="group flex flex-col items-center gap-2" href="https://instagram.com/institutosaberglobal" target="_blank" rel="noopener noreferrer">
        <div class="w-16 h-16 bg-surface-container-high rounded-full flex items-center justify-center group-hover:bg-pink-600 group-hover:text-on-primary transition-all duration-300">
          <span class="material-symbols-outlined text-3xl">photo_camera</span>
        </div>
        <span class="text-sm font-bold mt-2">@institutosaberglobal</span>
      </a>
      <a class="group flex flex-col items-center gap-2" href="https://linkedin.com/company/institutosaberglobal" target="_blank" rel="noopener noreferrer">
        <div class="w-16 h-16 bg-surface-container-high rounded-full flex items-center justify-center group-hover:bg-primary group-hover:text-on-primary transition-all duration-300">
          <span class="material-symbols-outlined text-3xl">public</span>
        </div>
        <span class="text-sm font-bold mt-2">Instituto de Educação Saber Global</span>
      </a>
    </div>
    <div class="pt-10 border-t border-outline-variant/10 text-on-surface-variant text-sm flex flex-col items-center justify-center space-y-2">
      <span class="font-bold text-on-surface">Instituto de Educação Saber Global</span>
      <span>CNPJ: 63.421.082/0001-68</span>
      <span class="flex items-center gap-2 mt-4 text-xs"><span class="material-symbols-outlined text-sm text-green-600">verified_user</span> Comprometidos com a proteção de seus dados conforme a LGPD.</span>
    </div>
  </div>
</section>

</Base>
